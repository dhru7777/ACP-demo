# Copy to local.env (gitignored). Railway: set each as a service variable.

ANTHROPIC_API_KEY=

# Buyer — spend wallet (private key only on buyer service when split)
BUYER_WALLET_PRIVATE_KEY=0x...
BUYER_WALLET_ADDRESS=0x...

# Seller — receive address (x402 payTo)
SELLER_PAYTO_ADDRESS=0x...

X402_NETWORK=eip155:84532
X402_FACILITATOR_URL=https://x402.org/facilitator

# Chain reads (wallet UI + x402)
BASE_SEPOLIA_RPC=https://sepolia.base.org
USDC_CONTRACT_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# Etherscan API v2 key (etherscan.io/myapikey) — works for Base Sepolia via chainid 84532
BASESCAN_API_KEY=
# BASESCAN_CHAIN_ID=84532
# BASESCAN_API_URL=https://api.etherscan.io/v2/api
EXPLORER_BASE_URL=https://sepolia.basescan.org

# Demo pricing: catalog USD per 1 USDC (10000 → $100 shoe = 0.01 USDC on-chain)
DEMO_CATALOG_USD_PER_USDC=10000

# Allow demo.html to sign buyer payments on seller (one-service demo only)
DEMO_SERVER_SIGN=true

# ERC-8004 — optional; agent ID + chain are auto-resolved when omitted
# Chain defaults from X402_NETWORK (eip155:84532). Agent ID is discovered by
# matching this service's public URL against 8004scan (seller wallet narrows search).
# Recommended for Railway / local ◎ profile (ACP service URL — not the Netlify frontend):
ERC8004_AGENT_ID=6832
ERC8004_SERVICE_URL=https://acp-demo-production.up.railway.app
# Live demo UI: https://dheeraj-agentic-communication-demo.netlify.app
# ERC8004_OWNER_ADDRESS=0x...
# 8004scan — testnet API auto-selected for Base Sepolia (84532)
# SCAN8004_API_BASE=https://testnet.8004scan.io/api/v1
# SCAN8004_WEB_BASE=https://testnet.8004scan.io
SCAN8004_API_KEY=

# ERC-8004 feedback — submitted via demo "Give feedback" button (not auto on pay)
# Buyer wallet must differ from agent owner; needs Base Sepolia ETH for giveFeedback gas.
# ERC8004_FEEDBACK_ON_PAY=false
