# Deployer or buyer private key (0x-prefixed). Never commit the real .env.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Base Sepolia RPC (public default; override if you have a provider key)
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Optional: contract verification
BASESCAN_API_KEY=

# Optional deal overrides (defaults match acp-demo buyer/seller + Circle USDC)
# BUYER=0x4299661b083f0920750BdFEc11EedeB49ee9e111
# SELLER=0x29A1885E5bE21263F840c20622E9D7ed6d35b5A0
# TOKEN=0x036CbD53842c5426634e7929541eC2318f3dCF7e
# AMOUNT=1000000
# DURATION_SECONDS=86400

# Set after deploy for Interact.s.sol
# ESCROW=0x
# ACTION=approve
